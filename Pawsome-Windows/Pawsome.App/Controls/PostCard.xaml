<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Pawsome.App.Controls.PostCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">

    <Border Style="{StaticResource CardSurfaceStyle}" Margin="0,0,0,16">
        <StackPanel>

            <!-- Author row -->
            <Grid Padding="14,10" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <muxc:PersonPicture Grid.Column="0" Width="38" Height="38"
                                    ProfilePicture="{Binding OwnerProfilePic, Converter={StaticResource UrlToImage}}"
                                    DisplayName="{Binding OwnerUsername}" />

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding OwnerUsername}" FontWeight="SemiBold" FontSize="14" />
                    <TextBlock Text="{Binding TimeAgo}" Style="{StaticResource SubtleCaptionStyle}" />
                </StackPanel>

                <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="6"
                        Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}">
                    <FontIcon Glyph="&#xE712;" FontSize="16" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Delete Post" Command="{Binding DeleteCommand}">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE74D;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>

            <!-- Cat photo -->
            <Button Command="{Binding OpenImageCommand}" Padding="0" BorderThickness="0"
                    Background="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Image Source="{Binding ImageUrl, Converter={StaticResource UrlToImage}}"
                       Stretch="UniformToFill" Height="300" />
            </Button>

            <!-- Details -->
            <StackPanel Padding="14,12,14,8" Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="16">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEB51;" FontSize="14" Foreground="{StaticResource BrandPurpleBrush}" />
                        <TextBlock Text="{Binding CatName}" FontWeight="SemiBold" FontSize="14" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                Visibility="{Binding AgeText, Converter={StaticResource StringToVis}}">
                        <FontIcon Glyph="&#xE787;" FontSize="14"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding AgeText}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="14" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Text="{Binding Description}" TextWrapping="Wrap" MaxLines="3"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="{Binding HasDescription, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Border Height="1" Margin="14,0"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Like / comment bar -->
            <StackPanel Orientation="Horizontal" Spacing="18" Padding="14,8">
                <Button Command="{Binding ToggleLikeCommand}" Background="Transparent" BorderThickness="0" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xEB52;"
                                  Foreground="{Binding IsLiked, Converter={StaticResource LikedToBrush}}" />
                        <TextBlock Text="{Binding LikeCount}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>

                <Button Command="{Binding OpenCommentsCommand}" Background="Transparent" BorderThickness="0" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE90A;" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding CommentCount}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
