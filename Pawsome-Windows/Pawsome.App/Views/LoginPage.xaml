<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Pawsome.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{StaticResource BrandDiagonalBrush}">
        <Border MaxWidth="430" Margin="24"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="34" CornerRadius="24"
                Background="#33000000">
            <StackPanel Spacing="24">

                <StackPanel Spacing="8" HorizontalAlignment="Center">
                    <TextBlock Text="🐾 Pawsome" FontSize="40" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="Find. Help. Reunite."
                               Foreground="#CCFFFFFF" FontSize="16"
                               HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Sign-in button (hidden while a sign-in is in progress) -->
                <Button Command="{x:Bind ViewModel.SignInCommand}"
                        IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InvBool}}"
                        Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource InvBoolToVis}}"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="White" Foreground="#3C4043"
                        BorderBrush="#DADCE0" BorderThickness="1"
                        CornerRadius="12" Padding="16,13">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Viewbox Width="20" Height="20">
                            <Canvas Width="48" Height="48">
                                <Path Fill="#EA4335" Data="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z" />
                                <Path Fill="#4285F4" Data="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z" />
                                <Path Fill="#FBBC05" Data="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z" />
                                <Path Fill="#34A853" Data="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Sign in with Google" FontWeight="SemiBold" FontSize="15"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <!-- In-progress state with a cancel escape hatch -->
                <StackPanel Spacing="12" HorizontalAlignment="Center"
                            Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <ProgressRing IsActive="True" Foreground="White" Width="30" Height="30" />
                    <TextBlock Text="Waiting for sign-in in your browser…"
                               Foreground="White" FontSize="13"
                               HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                    <Button Content="Cancel" Command="{x:Bind ViewModel.CancelCommand}"
                            HorizontalAlignment="Center" />
                </StackPanel>

                <InfoBar IsOpen="True"
                         Visibility="{x:Bind ViewModel.Error, Mode=OneWay, Converter={StaticResource StringToVis}}"
                         Severity="Error"
                         Message="{x:Bind ViewModel.Error, Mode=OneWay}"
                         IsClosable="False" />

                <!-- Desktop OAuth client id (required for Google sign-in) -->
                <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Header="Advanced — Google client ID">
                    <StackPanel Spacing="8" Padding="0,6">
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#CC000000"
                                   Text="Desktop sign-in needs a Google OAuth client of type 'Desktop app'. Create one in Google Cloud Console → APIs &amp; Services → Credentials, then paste its Client ID here." />
                        <TextBox Text="{x:Bind ViewModel.GoogleClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="xxxxxxxx.apps.googleusercontent.com" />
                    </StackPanel>
                </Expander>

                <TextBlock TextWrapping="Wrap" Foreground="#99FFFFFF" FontSize="12"
                           HorizontalAlignment="Center" TextAlignment="Center"
                           Text="Sign-in opens your browser to Google, then returns here automatically." />
            </StackPanel>
        </Border>
    </Grid>
</Page>
