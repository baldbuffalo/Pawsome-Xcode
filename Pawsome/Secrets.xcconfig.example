// Pawsome — iOS/macOS build secrets (EXAMPLE)
//
// 1. Copy this file to `Secrets.xcconfig` (same folder).
// 2. Replace the value below with your real GitHub token.
// 3. In Xcode: Project → Info → Configurations, point Debug/Release at this
//    xcconfig (or #include it from your existing config file).
//
// `Secrets.xcconfig` is git-ignored — never commit your real token.
//
// Token scope: fine-grained PAT with "Contents: Read and write" on
// baldbuffalo/Pawsome-assets (or a classic token with the `repo` scope).

GITHUB_TOKEN = ghp_replace_with_your_real_token

// Google sign-in (from GitHub secrets). Note: xcconfig values can't contain the
// '//' sequence, so the reversed id is given WITHOUT the scheme suffix and the
// app reads it as-is.
GOOGLE_CLIENT_ID = 000000000000-xxxxxxxx.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.000000000000-xxxxxxxx
